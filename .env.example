# Runtime
APP_ENV=local
DEPLOYMENT_MODE=local

# Database: Supabase-hosted PostgreSQL or local Postgres connection string
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cipla_execution
SUPABASE_URL=
SUPABASE_PROJECT_REF=

# Company exchange rates
COMPANY_LKR_PER_USD=310

# Local ingestion
DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
REPORTS_DIR=data/reports

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Protected demo
DEMO_ACCESS_MODE=local
DEMO_SHARED_PASSWORD=

# AI assistant
AI_PROVIDER=null
AI_API_KEY=
AI_MODEL=gemini-2.5-flash-lite
AI_MODEL_FALLBACKS=gemini-flash-lite-latest,gemini-2.0-flash-lite,gemini-2.0-flash-lite-001,gemini-2.0-flash
AI_CONTEXT_MAX_CHARS=24000
AI_CONTEXT_ROW_LIMIT=40
AI_REDACTION_ENABLED=false
AI_TIMEOUT_SECONDS=12
